{
  "name": "@corsair-dev/hub",
  "version": "0.1.0",
  "description": "Simple hosted relay and UI for Corsair Tunnel",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "dev-source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "build:watch": "tsup --watch",
    "dev": "tsx src/dev-entry.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "corsair": "workspace:*",
    "express": "^4.22.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^24.9.2",
    "tsup": "^8.0.1",
    "tsx": "^4.20.6",
    "typescript": "catalog:"
  },
  "files": [
    "dist",
    "public"
  ],
  "publishConfig": {
    "access": "public"
  }
}
