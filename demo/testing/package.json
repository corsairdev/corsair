    "@corsair-dev/firecrawl": "workspace:*",
    "@corsair-dev/github": "workspace:*",
    "@corsair-dev/gmail": "workspace:*",
    "@corsair-dev/googlecalendar": "workspace:*",
    "@corsair-dev/googlesheets": "workspace:*",
    "@corsair-dev/hubspot": "workspace:^",
    "@corsair-dev/linear": "workspace:*",
    "@corsair-dev/mcp": "workspace:*",
    "@corsair-dev/notion": "workspace:*",
    "@corsair-dev/onedrive": "workspace:*",
    "@corsair-dev/openweathermap": "workspace:*",
    "@corsair-dev/outlook": "workspace:*",
    "@corsair-dev/reddit": "workspace:*",
    "@corsair-dev/sharepoint": "workspace:*",
    "@corsair-dev/slack": "workspace:*",
    "@corsair-dev/teams": "workspace:*",
    "@corsair-dev/twilio": "workspace:*",
    "@corsair-dev/vapi": "workspace:*",
    "@corsair-dev/xquik": "workspace:*",
    "@tanstack/react-query": "^5.101.0",
    "@trpc/client": "^11.18.0",
    "@trpc/react-query": "^11.18.0",
    "@trpc/server": "^11.18.0",
    "better-sqlite3": "^12.11.1",
    "corsair": "workspace:*",
