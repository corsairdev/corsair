{
  "name": "@corsair/demo-plugins",
  "private": true,
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "test:manual": "tsx src/scripts/test-script.ts",
    "rebuild:sqlite": "pnpm rebuild better-sqlite3",
    "inngest:dev": "npx inngest-cli@latest dev",
    "agent": "tsx src/scripts/agent.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.185",
    "@corsair-dev/bitwarden": "workspace:*",
