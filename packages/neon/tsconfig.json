{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["esnext"],
    "types": ["node", "jest"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "./dist",
    "rootDir": "./",
    "composite": true,
    "incremental": true,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "skipLibCheck": true
  },
  "include": [
    "./index.ts",
    "./client.ts",
    "./error-handlers.ts",
    "./endpoints/**/*.ts",
    "./operations/**/*.ts",
    "./schema/**/*.ts"
  ],
  "exclude": ["dist", "node_modules", "**/*.test.ts", "jest.config.*"],
  "references": []
}
