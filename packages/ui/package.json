{
  "name": "@corsair-dev/ui",
  "version": "0.1.4",
  "description": "Plain-HTML UI helpers for Corsair permissions and related flows",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      }
    }
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "corsair": "workspace:*",
    "@corsair-dev/cal": "workspace:*",
    "@corsair-dev/gmail": "workspace:*",
    "@corsair-dev/googlecalendar": "workspace:*",
    "@corsair-dev/linear": "workspace:*",
    "@corsair-dev/slack": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.1",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist"
  ]
}
