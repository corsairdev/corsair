{
  "name": "@corsair-dev/studio",
  "version": "0.1.5",
  "description": "Local dashboard for inspecting and configuring your Corsair instance",
  "type": "module",
  "exports": {
    "./server": {
      "dev-source": "./src/server/index.ts",
      "types": "./dist/src/server/index.d.ts",
      "default": "./dist/server/index.js"
    }
  },
  "scripts": {
    "build": "pnpm run build:web && pnpm run build:server",
    "build:web": "vite build",
    "build:server": "tsup && tsc -p tsconfig.build.json",
    "dev:web": "vite",
    "dev:server": "tsx src/server/dev-entry.ts",
    "typecheck": "tsc --noEmit",
    "build:watch": "tsup --watch"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.85",
    "@ai-sdk/google": "^3.0.83",
    "@ai-sdk/groq": "^3.0.42",
    "@ai-sdk/openai": "^3.0.74",
    "@corsair-dev/cli": "workspace:*",
    "@corsair-dev/mcp": "workspace:*",
    "ai": "^6.0.208",
    "better-sqlite3": "^12.11.1",
    "corsair": "workspace:*",
    "kysely": "^0.29.2",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "tsup": "^8.0.1",
    "tsx": "^4.22.4",
    "vite": "^8.0.16"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
