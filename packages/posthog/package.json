{
  "name": "@corsair-dev/posthog",
  "version": "0.1.0",
  "description": "Posthog plugin for Corsair",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "dev-source": "./index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc --build --force && tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "uuid": "^11.1.0"
  },
  "peerDependencies": {
    "corsair": ">=0.1.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "corsair": "workspace:*",
    "tsup": "^8.0.1",
    "typescript": "catalog:",
    "zod": "^3.25.76"
  },
  "keywords": [
    "corsair",
    "posthog",
    "plugin"
  ],
  "author": "",
  "license": "Apache-2.0",
  "files": [
    "dist"
  ]
