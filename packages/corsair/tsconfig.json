{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["esnext", "dom", "dom.iterable"],
    "types": ["node", "jest"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "./dist",
    "rootDir": "./",
    "composite": true,
    "incremental": true,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "skipLibCheck": true,
    "paths": {
      "@corsair-dev/slack": ["../slack/index.ts"]
    }
  },
  "include": ["./**/*"],
  "exclude": [
    "dist",
    "node_modules",
    "sandbox/**/*",
    "tests/**/*.test.ts",
    "setup/**/*.test.ts"
  ],
  "references": []
}
