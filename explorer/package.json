{
  "name": "corsair-explorer",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone HTTP catalog of every Corsair plugin and its api, webhook, and db operations.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "corsair-explorer": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "build:watch": "tsup --watch",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^24.10.1",
    "tsup": "^8.0.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist",
    "data"
  ]
}
